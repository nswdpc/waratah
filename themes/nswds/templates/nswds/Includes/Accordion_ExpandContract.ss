<% if $Accordion_ExpandContract %>
<div class="nsw-accordion__toggle">
  <button type="button" aria-label="<%t nswds.ACCORDION_ARIA_LABEL_EXPAND_ALL_SECTIONS 'Expand all sections' %>"><%t nswds.EXPAND_ALL 'Expand all' %></button>
  <button type="button" aria-label="<%t nswds.ACCORDION_ARIA_LABEL_COLLAPSE_ALL_SECTIONS 'Collapse all sections' %>"><%t nswds.COLLAPSE_ALL 'Collapse all' %></button>
</div>
<% end_if %>
